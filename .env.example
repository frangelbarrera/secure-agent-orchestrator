# Application settings
APP_NAME="Secure Agent Orchestrator"
APP_DESCRIPTION="REST API for orchestrating async commands to remote security agents"
APP_VERSION="1.0.0"
LICENSE_NAME="MIT"
CONTACT_NAME="Frangel Barrera"
CONTACT_EMAIL="security@frangelbarrera.dev"

# Environment: local, staging, or production
ENVIRONMENT="local"

# Cryptography - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="CHANGE-ME-TO-A-SECURE-RANDOM-STRING"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite default - no setup required)
SQLITE_URI="./db.sqlite"
SQLITE_SYNC_PREFIX="sqlite:///"
SQLITE_ASYNC_PREFIX="sqlite+aiosqlite:///"

# First admin user
ADMIN_NAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE-ME-TO-A-SECURE-PASSWORD"

# CRUD Admin interface
CRUD_ADMIN_ENABLED=true
CRUD_ADMIN_MOUNT_PATH="/admin"
CRUD_ADMIN_MAX_SESSIONS=10
CRUD_ADMIN_SESSION_TIMEOUT=1440
SESSION_SECURE_COOKIES=true
CRUD_ADMIN_TRACK_EVENTS=true
CRUD_ADMIN_TRACK_SESSIONS=true
CRUD_ADMIN_REDIS_ENABLED=false

# CORS (relax in production)
CORS_ORIGINS=["*"]
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Rate limiting
DEFAULT_RATE_LIMIT_LIMIT=10
DEFAULT_RATE_LIMIT_PERIOD=3600

# Client-side cache (seconds)
CLIENT_CACHE_MAX_AGE=60
